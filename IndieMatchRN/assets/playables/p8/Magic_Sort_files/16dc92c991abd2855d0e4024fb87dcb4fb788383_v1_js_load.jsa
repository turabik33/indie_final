tartTime) this.startTime = Date.now();\n\n\t\t\tif (!this.uuid) {\n\n\t\t\t\tlet uuidStorageKey;\n\n\t\t\t\tif (Settings['uuid-storage-key'] && Settings['uuid-storage-key'].value) uuidStorageKey = Settings['uuid-storage-key'].value;\n\t\t\t\telse if (Settings['uuid-storage-key']) uuidStorageKey = Settings['uuid-storage-key'];\n\n\n\t\t\t\tthis.uuid = this.generateUUID(uuidStorageKey);\n\t\t\t}\n\t\t\tif (!this.prosperSessionId) this.prosperSessionId = this.generateUUID();\n\n\t\t\tif (this.isGeoNeeded) {\n\n\t\t\t\tBroadcast.once('Geo Loaded', function() {\n\n\t\t\t\t\twhile (URLTracking.holdUntilGeo.length) {\n\n\t\t\t\t\t\tvar event = URLTracking.holdUntilGeo.pop();\n\t\t\t\t\t\tif (MRAID.isViewable || Settings[\"track-events-on-viewable\"] === false) {\n\t\t\t\t\t\t\tURLTracking.sendAction(event[0], event[1]);\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tURLTracking.holdEvents.push(event);\n\t\t\t\t\t\t}\n\n\t\t\t\t\t}\n\n\t\t\t\t}, 'geo-loaded');\n\n\t\t\t\tvar geoUrl = typeof Settings['track-geo-url'] == 'string' ? Settings['track-geo-url'] : Settings['track-geo-url'].value;\n\n\t\t\t\tif (geoUrl) {\n\n\t\t\t\t\tvar xhr = new XMLHttpRequest();\n\t\t\t\t\tvar self = this;\n\n\t\t\t\t\txhr.onload = function(e) {\n\t\t\t\t\t\tif (xhr.readyState === 4) {\n\t\t\t\t\t\t\tif (!(xhr.status >= 200 && xhr.status < 300)) {\n\t\t\t\t\t\t\t\tconsole.error('Geo request status is not 2xx: ', xhr.status);\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tself.geo = xhr.getResponseHeader('X-Geo') || 'XX';\n\t\t\t\t\t\t\tBroadcast.call('Geo Loaded');\n\t\t\t\t\t\t}\n\t\t\t\t\t};\n\n\t\t\t\t\txhr.onerror = function(e) {\n\t\t\t\t\t\tconsole.error('Get geo err:', xhr.statusText);\n\t\t\t\t\t\tself.geo = 'XX';\n\t\t\t\t\t\tBroadcast.call('Geo Loaded');\n\t\t\t\t\t};\n\n\t\t\t\t\ttry {\n\t\t\t\t\t\txhr.open(\"GET\", geoUrl, true);\n\t\t\t\t\t\txhr.send();\n\t\t\t\t\t} catch (e) {\n\t\t\t\t\t\tconsole.error('Get geo err:', xhr.statusText);\n\t\t\t\t\t\tthis.geo = 'XX';\n\t\t\t\t\t\tBroadcast.call('Geo Loaded'